{
  "name": "ibm-cloud-garage-tdd",
  "version": "1.0.0",
  "description": "TDD exercises from IBM Cloud Garage — Jest + Babel on Node.js",
  "private": true,
  "scripts": {
    "test": "jest --verbose",
    "test:coverage": "jest --verbose --coverage",
    "tdd": "jest --verbose --watch --onlyChanged",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thitipongroo/ibm-cloud-garage-tdd.git"
  },
  "author": "Thitipong Roongpraser",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "husky": "^9.1.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "server/**/*.js",
      "!server/**/*.spec.js"
    ]
  }
}
